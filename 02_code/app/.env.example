# Copy to .env and adjust. The SAME compose file runs locally and on the VPS;
# only these values change.

# --- database (serving DB; created fresh from serving-data/serving.sql) -------
POSTGRES_USER=gis
POSTGRES_PASSWORD=gis            # CHANGE THIS on the VPS
POSTGRES_DB=broadband

# --- web / TLS ----------------------------------------------------------------
# Local:  :80                 (plain HTTP, no certificate)
# VPS:    coverage.example.ua (a real domain -> automatic HTTPS via Caddy)
SITE_ADDRESS=:80
HTTP_PORT=80
HTTPS_PORT=443

# --- API ----------------------------------------------------------------------
# Only needed for the Vite dev server hitting the API cross-origin. In the
# Docker stack the frontend is same-origin behind Caddy, so CORS is unused.
CORS_ORIGINS=http://localhost:5173
